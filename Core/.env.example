# Copy these values into .env. Never commit the real shared secret.
REPORT_EMBED_SECRET=replace-with-the-same-random-secret-used-by-payara
REPORT_EMBED_ALLOWED_ANCESTORS=http://java-dashboard-host:port

# True requires HTTPS and is needed when the Java and Django hostnames are
# cross-site (not merely different ports on the same hostname).
REPORT_EMBED_CROSS_SITE_COOKIES=False
